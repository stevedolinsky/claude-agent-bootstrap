{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Pipeline Progress",
      "url": "/d/pipeline-progress",
      "icon": "dashboard",
      "type": "link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Active Repos",
      "description": "Repos with event activity in last 1h. Shows 0 when no work has been processed.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(count by (repo) (agent_issues_total)) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Workers",
      "description": "Active workers across all repos (spawned minus completed in selected time range)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(agent_in_flight) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Issues Done / hr",
      "description": "Rate of completed issues across all repos",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "round(sum(increase(agent_issues_total{action=\"done\"}[1h]))) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Errors (last 1h)",
      "description": "Total errors across all repos in last hour",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "round(sum(increase(agent_issues_total{action=\"error\"}[1h]))) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "table",
      "title": "Repo Health",
      "description": "Per-repo last activity \u2014 click a repo to drill down",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "timeFrom": "1h",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"claude-agent\", action=~\"queue_added|spawned|done|error|blocked|step_started|step_completed\"}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "tsNs",
                "desc": false
              }
            ]
          }
        },
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "repo": {
                "aggregations": [],
                "operation": "groupby"
              },
              "action": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              },
              "number": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              },
              "ts": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "repo": "Repository",
              "action (lastNotNull)": "Last Activity",
              "number (lastNotNull)": "Last Issue",
              "ts (lastNotNull)": "Last Event"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Repository"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Repo Detail",
                    "url": "/d/claude-agent-dashboard?var-repo=${__value.text}",
                    "targetBlank": false
                  },
                  {
                    "title": "View Pipeline",
                    "url": "/d/pipeline-progress?var-repo=${__value.text}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Last Activity"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "done": {
                        "text": "Completed",
                        "color": "green"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "spawned": {
                        "text": "Working",
                        "color": "yellow"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "step_started": {
                        "text": "Working",
                        "color": "yellow"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "step_completed": {
                        "text": "Working",
                        "color": "yellow"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "queue_added": {
                        "text": "Queued",
                        "color": "blue"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "error": {
                        "text": "Error",
                        "color": "red"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "blocked": {
                        "text": "Blocked",
                        "color": "orange"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Repository",
            "desc": false
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Fleet Event Rate",
      "description": "Events per second across all repos, grouped by action",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (action) (rate({job=\"claude-agent\", action!=\"heartbeat\"} | json [$__auto]))",
          "refId": "A",
          "legendFormat": "{{action}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "claude-agent",
    "fleet"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "title": "Fleet Overview",
  "uid": "fleet-overview",
  "version": 1,
  "timezone": "browser"
}
