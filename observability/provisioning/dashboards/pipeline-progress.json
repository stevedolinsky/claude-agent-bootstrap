{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Back to Fleet Overview",
      "url": "/d/fleet-overview",
      "icon": "external link",
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Repo Detail",
      "url": "/d/claude-agent-dashboard?var-repo=${__var.repo}",
      "icon": "dashboard",
      "type": "link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Status",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Queue Depth",
      "description": "Pending items (queued minus completed/errored in selected time range)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "agent_queue_depth{repo=~\"$repo\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Worker Status",
      "description": "Whether a worker is currently active (from agent_in_flight gauge). Resets to 0 on restart.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "agent_in_flight{repo=~\"$repo\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "blue",
                "value": 1
              }
            ]
          },
          "noValue": "Idle",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Idle",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 100,
                "result": {
                  "text": "Active",
                  "index": 1
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Current Issue",
      "description": "Issue number of the most recently dispatched worker (from latest spawned event)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"claude-agent\", action=\"spawned\", repo=~\"$repo\"}",
          "refId": "A",
          "maxLines": 1
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "ts": true,
              "action": true,
              "event_type": true,
              "repo": true,
              "Line": true,
              "labels": true,
              "Time": true,
              "tsNs": true,
              "id": true,
              "worker_pid": true
            },
            "renameByName": {
              "number": "Issue #",
              "model": "Model"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "noValue": "\u2014"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/Issue/",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Avg Worker Duration",
      "description": "Average worker execution time (spawned to done) in the last 24h",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "avg_over_time({job=\"claude-agent\", action=\"done\", repo=~\"$repo\"} | json | unwrap duration_seconds [$__range])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "unit": "s",
          "noValue": "\u2014"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "gauge",
      "title": "Daily Cost",
      "description": "Total API spend in the last 24 hours (sum of per-event costs). Green <$25, Yellow $25-$40, Red >$40.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum_over_time({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap estimated_cost_usd [24h])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 25
              },
              {
                "color": "red",
                "value": 40
              }
            ]
          },
          "min": 0,
          "max": 50,
          "unit": "currencyUSD",
          "noValue": "$0.00"
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Avg Cost / Issue",
      "description": "Average estimated API cost per worker invocation (last 24h)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "avg_over_time({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap estimated_cost_usd [$__range])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "currencyUSD",
          "noValue": "$0.00"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "row",
      "title": "Progress",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Active Issues",
      "description": "Current status of issues in the pipeline \u2014 queued, working, completed, or blocked",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 6
      },
      "timeFrom": "1h",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"claude-agent\", action=~\"queue_added|spawned|done|error|blocked\", repo=~\"$repo\"}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "tsNs",
                "desc": false
              }
            ]
          }
        },
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "number": {
                "aggregations": [],
                "operation": "groupby"
              },
              "action": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              },
              "repo": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              },
              "ts": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "number": "Issue #",
              "action (lastNotNull)": "Status",
              "repo (lastNotNull)": "repo",
              "ts (lastNotNull)": "Last Update"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Issue #"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View on GitHub",
                    "url": "https://github.com/${__data.fields.repo}/issues/${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "queue_added": {
                        "text": "Queued",
                        "color": "blue"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "spawned": {
                        "text": "Working",
                        "color": "yellow"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "done": {
                        "text": "Completed",
                        "color": "green"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "error": {
                        "text": "Failed",
                        "color": "red"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "blocked": {
                        "text": "Blocked",
                        "color": "orange"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Update",
            "desc": true
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Recent Queue Activity",
      "description": "Recently queued items",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "timeFrom": "1h",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"claude-agent\", action=\"queue_added\", repo=~\"$repo\"}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "tsNs",
                "desc": false
              }
            ]
          }
        },
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "action": true,
              "Line": true,
              "labels": true,
              "Time": true,
              "tsNs": true,
              "id": true,
              "event_type": true,
              "model": true,
              "queue_depth": true
            },
            "renameByName": {
              "number": "Issue #",
              "ts": "Queued At"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Issue #"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View on GitHub",
                    "url": "https://github.com/${__data.fields.repo}/issues/${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Queued At",
            "desc": true
          }
        ]
      }
    },
    {
      "type": "row",
      "title": "Cost & Timeline",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cumulative Cost vs Budget",
      "description": "Running total spend across all models vs $50 budget (red line). Always shows full 7-day history regardless of dashboard time picker.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(agent_cost_usd_total{repo=~\"$repo\"})",
          "refId": "Cumulative",
          "legendFormat": "Cumulative Spend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "pointSize": 6,
            "showPoints": "always",
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              {
                "color": "transparent",
                "value": null
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "transformations": []
    },
    {
      "type": "timeseries",
      "title": "Cost Per Worker",
      "description": "Estimated API cost per worker invocation, stacked by model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (model) (rate({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap estimated_cost_usd [$__auto]))",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Work Timeline",
      "description": "Worker spawns and completions over time",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"claude-agent\", action=\"spawned\", repo=~\"$repo\"} [$__auto])",
          "refId": "Spawned",
          "legendFormat": "Spawned"
        },
        {
          "expr": "count_over_time({job=\"claude-agent\", action=\"done\", repo=~\"$repo\"} [$__auto])",
          "refId": "Done",
          "legendFormat": "Done"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "row",
      "title": "Token Usage",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false
    },
    {
      "type": "barchart",
      "title": "Tokens by Issue",
      "description": "Token breakdown per issue \u2014 input (blue), output (green), cache read (gray), cache create (yellow)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (number) (sum_over_time({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap input_tokens [$__range]))",
          "refId": "Input",
          "legendFormat": "Input Tokens",
          "instant": true
        },
        {
          "expr": "sum by (number) (sum_over_time({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap output_tokens [$__range]))",
          "refId": "Output",
          "legendFormat": "Output Tokens",
          "instant": true
        },
        {
          "expr": "sum by (number) (sum_over_time({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap cache_read_tokens [$__range]))",
          "refId": "CacheRead",
          "legendFormat": "Cache Read",
          "instant": true
        },
        {
          "expr": "sum by (number) (sum_over_time({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap cache_creation_tokens [$__range]))",
          "refId": "CacheCreate",
          "legendFormat": "Cache Create",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#808080",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Create"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "stacking": "normal",
        "showValue": "auto",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        },
        "xTickLabelRotation": 0
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "number": "Issue #"
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Rate",
      "description": "Output token generation rate \u2014 spikes indicate heavy generation, flat indicates idle",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"claude-agent\", action=\"cost_tracked\", repo=~\"$repo\"} | json | unwrap output_tokens [$__auto]))",
          "refId": "OutputRate",
          "legendFormat": "Output Tokens/s"
        },
        {
