{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Back to Fleet Overview",
      "url": "/d/fleet-overview",
      "icon": "external link",
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Pipeline Progress",
      "url": "/d/pipeline-progress?var-repo=${__var.repo}",
      "icon": "dashboard",
      "type": "link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Issue Queue",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Issue Queue",
      "description": "All issues for this repo with status derived from events. Click Issue # to view on GitHub.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "timeFrom": "1h",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"claude-agent\", action=~\"queue_added|spawned|step_started|done|error|blocked\", repo=~\"$repo\"}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "tsNs",
                "desc": false
              }
            ]
          }
        },
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "number": {
                "aggregations": [],
                "operation": "groupby"
              },
              "action": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              },
              "repo": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              },
              "ts": {
                "aggregations": [
                  "lastNotNull"
                ],
                "operation": "aggregate"
              }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "number": "Issue #",
              "action (lastNotNull)": "Status",
              "repo (lastNotNull)": "repo",
              "ts (lastNotNull)": "Last Update"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Issue #"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View on GitHub",
                    "url": "https://github.com/${__data.fields.repo}/issues/${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "queue_added": {
                        "text": "Pending",
                        "color": "blue"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "spawned": {
                        "text": "In Progress",
                        "color": "yellow"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "step_started": {
                        "text": "In Progress",
                        "color": "yellow"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "done": {
                        "text": "Completed",
                        "color": "green"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "error": {
                        "text": "Failed",
                        "color": "red"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "blocked": {
                        "text": "Blocked",
                        "color": "orange"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Update",
            "desc": true
          }
        ]
      }
    },
    {
      "type": "row",
      "title": "Operational Stats",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "In-Flight",
      "description": "Currently in-flight work (spawned - done - errors)",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(agent_in_flight{repo=~\"$repo\"}) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
