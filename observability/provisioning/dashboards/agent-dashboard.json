    {
      "type": "timeseries",
      "title": "Issue Processing Time",
      "description": "Worker execution time (spawned to done) per issue",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"claude-agent\", action=\"done\", repo=~\"$repo\"}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "duration_seconds",
                "destinationType": "number"
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "tsNs": true,
              "id": true,
              "action": true,
              "event_type": true,
              "repo": true,
              "ts": true,
              "model": true
            },
            "renameByName": {
              "duration_seconds": "Duration (s)"
            }
          }
        },
        {
          "id": "partitionByValues",
          "options": {
            "fields": ["number"],
            "keepFields": false,
            "naming": {
              "withNames": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barMaxWidth": 50,
            "lineWidth": 0,
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
